PORT=3001

# CORS — comma-separated frontend URLs
ALLOWED_ORIGINS=http://localhost:8080,https://us.omuzbox.com

# Email → info@omuzbox.com (Resend: https://resend.com)
RESEND_API_KEY=
RESEND_FROM=Omuzbox <notifications@yourdomain.com>
NOTIFY_EMAIL=info@omuzbox.com

# Telegram admin alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Meta Conversions API (server-side Lead events)
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_EVENT_SOURCE_URL=https://us.omuzbox.com
